# ── Meta / Facebook ──────────────────────────────────────────────────────────
META_ACCESS_TOKEN=your_system_user_token_here
META_AD_ACCOUNT_ID=act_XXXXXXXXX

# ── GoHighLevel ───────────────────────────────────────────────────────────────
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_location_id_here
# Komma-gescheiden lijst van 4 workflow IDs
GHL_WORKFLOW_IDS=wf_id_1,wf_id_2,wf_id_3,wf_id_4

# ── E-mail alerts (SMTP) ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@jouwdomein.nl
SMTP_PASSWORD=your_app_password_here
ALERT_FROM=alerts@jouwdomein.nl
ALERT_TO=dante@unbreakablesystems.nl

# ── Monitor instellingen ──────────────────────────────────────────────────────
# Tijdvenster in minuten voor vergelijking (standaard: 30)
WINDOW_MINUTES=30
